# --- Database (Neon Postgres) ---
# Create a project at https://neon.tech and copy the pooled connection string.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# --- Auth.js ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Google OAuth credentials from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (local):      http://localhost:3000/api/auth/callback/google
# Authorized redirect URI (production): https://YOUR-APP.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# The ONLY email allowed to sign in. Any other Google account is rejected.
ALLOWED_EMAIL="kulhariajay19@gmail.com"
